@model IEnumerable<ProductionManagementSystem.Web.Models.ProductionLine>

@{
    ViewData["Title"] = "Интерактивная панель линий";
}

<!-- Вставляем токен в начало представления -->
@Html.AntiForgeryToken()

<h2>@ViewData["Title"]</h2>

<form method="get" class="mb-3">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" name="available" value="true" id="availableCheckbox" @(ViewBag.Available ? "checked" : "") onchange="this.form.submit()">
        <label class="form-check-label" for="availableCheckbox">
            Только доступные (активные)
        </label>
        <input type="hidden" name="available" value="false" />
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить линию</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Статус</th>
            <th>Коэффициент эффективности</th>
            <th>Текущий заказ</th>
            <th>Прогресс выполнения</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td class="@(item.Status == "Active" ? "text-success" : "text-danger")">
                    @(item.Status switch
                    {
                        "Active" => "Активна",
                        "Stopped" => "Остановлена",
                        _ => item.Status
                    })
                </td>
                <td>@Html.DisplayFor(modelItem => item.EfficiencyFactor)</td>
                <td>@(item.CurrentWorkOrder?.Product?.Name ?? "Нет")</td>
                <td>
                    @if (item.CurrentWorkOrder != null)
                    {
                        <div class="progress">
                          <div class="progress-bar" role="progressbar" style="width: 0%;">0%</div>
                        </div>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Редактировать</a>
                    <a asp-action="Schedule" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Расписание</a>
                    <button type="button" class="btn btn-sm btn-success" onclick="updateLineStatus(@item.Id, 'Active')">Запустить</button>
                    <button type="button" class="btn btn-sm btn-warning" onclick="updateLineStatus(@item.Id, 'Stopped')">Остановить</button>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('Вы уверены, что хотите удалить линию \'@item.Name\'? Все назначенные заказы будут отвязаны.')">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function updateLineStatus(lineId, newStatus) {
        // Проверяем, что lineId - число и newStatus - допустимое значение
        if (isNaN(lineId) || (newStatus !== 'Active' && newStatus !== 'Stopped')) {
             console.error('Invalid parameters passed to updateLineStatus:', lineId, newStatus);
             alert('Произошла ошибка: неверные параметры.');
             return;
        }

        // Находим токен CSRF
        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        if (!tokenElement) {
            console.error('CSRF token not found in the document.');
            alert('Произошла ошибка: отсутствует токен безопасности.');
            return;
        }
        const token = tokenElement.value;

        fetch(`/ProductionLines/UpdateStatus/${lineId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ status: newStatus })
        })
        .then(response => {
            if (response.ok) {
                alert(`Статус линии изменён на ${(newStatus === "Active" ? "Активна" : "Остановлена")}`);
                location.reload(); // Reload to reflect changes
            } else {
                response.text().then(text => {
                    console.error('Server error:', text);
                    alert('Ошибка при изменении статуса: ' + text);
                }).catch(() => {
                    alert('Ошибка при изменении статуса.');
                });
            }
        })
        .catch(error => {
            console.error('Fetch error:', error);
            alert('Произошла ошибка сети или другой ошибки при выполнении запроса.');
        });
    }
</script>