@model ProductionManagementSystem.Web.Models.ProductionLine

@{
    ViewData["Title"] = "Расписание линии " + Model.Name;
    var availableOrders = ViewBag.AvailableOrders as List<ProductionManagementSystem.Web.Models.WorkOrder>;
}

<h2>@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h3>Назначенные заказы</h3>
@if (Model.AssignedWorkOrders != null && Model.AssignedWorkOrders.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Номер заказа</th>
                <th>Продукт</th>
                <th>Количество</th>
                <th>Статус</th>
                <th>Прогресс</th>
                <th>Срок выполнения</th>
                <th>Время начала</th>
                <th></th>
            </tr>
        </thead>
        <!-- Добавлен ID для удобного поиска в JS -->
        <tbody id="assigned-orders-table">
            @foreach (var order in Model.AssignedWorkOrders)
            {
                <tr id="order-row-@order.Id" data-status="@order.Status">
                    <td>@order.Id</td>
                    <td>@order.Product?.Name</td>
                    <td>@order.Quantity</td>
                    
                    <!-- Класс для быстрого доступа к ячейке статуса -->
                    <td class="status-cell @(order.Status == "Completed" ? "text-success" : order.Status == "Cancelled" ? "text-danger" : order.Status == "InProgress" ? "text-info" : "text-warning")">
                        @(order.Status switch
                        {
                            "Pending" => "Ожидает",
                            "InProgress" => "В процессе",
                            "Completed" => "Завершён",
                            "Cancelled" => "Отменён",
                            _ => order.Status
                        })
                    </td>
                    
                    <td>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" 
                                 style="width: @order.Progress%;" 
                                 aria-valuenow="@order.Progress" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                                @order.Progress%
                            </div>
                        </div>
                    </td>
                    
                    <td>@order.EstimatedEndDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                    
                    <!-- Класс для управления кнопками действий -->
                    <td class="action-cell">
                        @if (order.Status == "Pending")
                        {
                            <form asp-action="AssignOrder" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productionLineId" value="@Model.Id" />
                                <input type="hidden" name="workOrderId" value="@order.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Запустить</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Для этой линии пока не назначено ни одного заказа.</p>
}

<h3>Доступные заказы для назначения</h3>
@if (availableOrders != null && availableOrders.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Номер заказа</th>
                <th>Продукт</th>
                <th>Количество</th>
                <th>Срок выполнения</th>
                <th>Время начала</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in availableOrders)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.Product?.Name</td>
                    <td>@order.Quantity</td>
                    <td>@order.EstimatedEndDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <form asp-action="AssignOrder" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productionLineId" value="@Model.Id" />
                            <input type="hidden" name="workOrderId" value="@order.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">Назначить на линию</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Нет доступных заказов для назначения на эту линию.</p>
}

<a asp-action="Index" class="btn btn-secondary">Назад к списку линий</a>

<!-- ⚡ СКРИПТ РЕАЛЬНОГО ВРЕМЕНИ ⚡ -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Функция обновления статусов и прогресса
        function updateOrdersStatus() {
            const rows = document.querySelectorAll('#assigned-orders-table tr');
            const now = new Date();

            rows.forEach(row => {
                const orderId = row.id.replace('order-row-', '');
                const currentStatus = row.getAttribute('data-status');

                // Оптимизация: обновляем только заказы, которые ещё идут или ожидают
                if (currentStatus === 'InProgress' || currentStatus === 'Pending') {
                    fetch(`/WorkOrders/GetOrderDetails/${orderId}`)
                        .then(response => {
                            if (!response.ok) throw new Error('Network response was not ok');
                            return response.json();
                        })
                        .then(data => {
                            // 1. Обновляем атрибут статуса в DOM
                            row.setAttribute('data-status', data.status);

                            // 2. Обновляем ячейку статуса
                            const statusCell = row.querySelector('.status-cell');
                            if (statusCell) {
                                let statusText = '';
                                let statusClass = '';
                                switch(data.status) {
                                    case 'Pending': 
                                        statusText = 'Ожидает'; statusClass = 'text-warning'; break;
                                    case 'InProgress': 
                                        statusText = 'В процессе'; statusClass = 'text-info'; break;
                                    case 'Completed': 
                                        statusText = 'Завершён'; statusClass = 'text-success'; break;
                                    case 'Cancelled': 
                                        statusText = 'Отменён'; statusClass = 'text-danger'; break;
                                    default: 
                                        statusText = data.status; statusClass = 'text-secondary';
                                }
                                statusCell.textContent = statusText;
                                statusCell.className = `status-cell ${statusClass}`;
                            }

                            // 3. Обновляем прогресс-бар
                            const progressBar = row.querySelector('.progress-bar');
                            if (progressBar) {
                                let percent = 0;
                                if (data.status === 'Completed') {
                                    percent = 100;
                                } else if (data.status === 'InProgress') {
                                    const start = new Date(data.startDate);
                                    const end = new Date(data.estimatedEndDate);
                                    const total = end - start;
                                    
                                    if (total > 0) {
                                        const elapsed = now - start;
                                        // Расчет процента с защитой от отрицательных и >100 значений
                                        percent = Math.min(100, Math.max(0, Math.round((elapsed / total) * 100)));
                                    }
                                }
                                
                                progressBar.style.width = `${percent}%`;
                                progressBar.textContent = `${percent}%`;
                                progressBar.setAttribute('aria-valuenow', percent);
                            }

                            // 4. Если заказ завершён, заменяем кнопку на галочку
                            if (data.status === 'Completed') {
                                const actionCell = row.querySelector('.action-cell');
                                if (actionCell) {
                                    actionCell.innerHTML = '<span class="text-success fw-bold">✔ Завершён</span>';
                                }
                            }
                        })
                        .catch(error => console.error(`Ошибка обновления заказа #${orderId}:`, error));
                }
            });
        }

        // Запускаем обновление сразу и повторяем каждые 3 секунды
        updateOrdersStatus();
        setInterval(updateOrdersStatus, 3000);
    });
</script>