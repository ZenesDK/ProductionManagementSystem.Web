@model ProductionManagementSystem.Web.Models.ProductionLine

@{
    ViewData["Title"] = "Создать производственную линию";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create"> <!-- Важно: только asp-action, без asp-controller -->
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group mb-3">
        <label asp-for="Name" class="control-label">Название</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <!-- Status is set automatically to Stopped -->
    <div class="form-group mb-3">
        <label asp-for="EfficiencyFactor" class="control-label">Коэффициент эффективности (0.5 - 2.0)</label>
        <input asp-for="EfficiencyFactor" class="form-control" type="number" step="0.1" min="0.5" max="2.0" value="1.0" />
        <span asp-validation-for="EfficiencyFactor" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Создать" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a> <!-- Используем asp-action для ссылки на Index в том же контроллере -->
    </div>
</form>