@model ProductionManagementSystem.Web.Models.Product

@{
    ViewData["Title"] = "Удалить продукт";
}

<h2>@ViewData["Title"]</h2>

<h3>Вы уверены, что хотите удалить этот продукт?</h3>
<p class="text-danger">Это также удалит все связанные материалы!</p>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Название</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            
            <dt class="col-sm-3">Категория</dt>
            <dd class="col-sm-9">@Model.Category</dd>
            
            <dt class="col-sm-3">Время производства</dt>
            <dd class="col-sm-9">@Model.ProductionTimePerUnit мин/шт</dd>
            
            <dt class="col-sm-3">Минимальный запас</dt>
            <dd class="col-sm-9">@Model.MinimalStock</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>