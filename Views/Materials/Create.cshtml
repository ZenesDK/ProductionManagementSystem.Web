@model ProductionManagementSystem.Web.Models.Material

@{
    ViewData["Title"] = "Добавить материал";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group mb-3">
        <label asp-for="Name" class="control-label">Название</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Quantity" class="control-label">Количество</label>
        <input asp-for="Quantity" class="form-control" type="number" step="any" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="UnitOfMeasure" class="control-label">Единицы измерения</label>
        <select asp-for="UnitOfMeasure" 
                asp-items="@(new SelectList(ViewBag.UnitsOfMeasure))" 
                class="form-select" 
                required>
            <option value="">-- Выберите --</option>
        </select>
        <span asp-validation-for="UnitOfMeasure" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="MinimalStock" class="control-label">Минимальный запас</label>
        <input asp-for="MinimalStock" class="form-control" type="number" step="any" />
        <span asp-validation-for="MinimalStock" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Создать" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </div>
</form>