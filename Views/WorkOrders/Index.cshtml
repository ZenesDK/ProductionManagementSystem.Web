@model IEnumerable<ProductionManagementSystem.Web.Models.WorkOrder>

@{
    ViewData["Title"] = "Панель заказов";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" class="mb-3">
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <label for="status" class="col-form-label">Статус</label>
        </div>
        <div class="col-auto">
            <select name="status" id="status" class="form-select" onchange="this.form.submit()">
                <option value="">Все</option>
                <option value="Pending" selected="@(ViewBag.Status == "Pending" ? "selected" : null)">Ожидает</option>
                <option value="InProgress" selected="@(ViewBag.Status == "InProgress" ? "selected" : null)">В процессе</option>
                <option value="Completed" selected="@(ViewBag.Status == "Completed" ? "selected" : null)">Завершён</option>
                <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled" ? "selected" : null)">Отменён</option>
            </select>
        </div>
        <div class="col-auto">
            <label for="date" class="col-form-label">Дата завершения</label>
        </div>
        <div class="col-auto">
            <input type="date" name="date" id="date" class="form-control" value="@(ViewBag.Date?.ToString("yyyy-MM-dd"))" onchange="this.form.submit()" />
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">Создать заказ</a>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Номер</th>
            <th>Продукт</th>
            <th>Количество</th>
            <th>Статус</th>
            <th>Прогресс</th>
            <th>Срок выполнения</th>
            <th>Время начала</th>
            <th>Производственная линия</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr id="order-row-@item.Id">
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.Product.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                <td class="status-cell-@item.Id">
                    <span class="badge @(item.Status == "Completed" ? "bg-success" : item.Status == "Cancelled" ? "bg-danger" : item.Status == "InProgress" ? "bg-info" : "bg-warning")">
                        @(item.Status switch
                        {
                            "Pending" => "Ожидает",
                            "InProgress" => "В процессе",
                            "Completed" => "Завершён",
                            "Cancelled" => "Отменён",
                            _ => item.Status
                        })
                    </span>
                </td>
                <td>
                    <div class="progress" style="height: 20px;">
                        <!-- ДОБАВЛЕНЫ АТРИБУТЫ data-start И data-end -->
                        <div class="progress-bar progress-bar-@item.Id real-time-progress" role="progressbar"
                             data-start="@item.StartDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                             data-end="@item.EstimatedEndDate.ToString("yyyy-MM-ddTHH:mm:ss")"
                             style="width: @item.Progress%;"
                             aria-valuenow="@item.Progress"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @item.Progress%
                        </div>
                    </div>
                </td>
                <td>@item.EstimatedEndDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(item.ProductionLine?.Name ?? "Не назначена")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Редактировать</a>
                    @if (item.Status == "Pending" || item.Status == "InProgress")
                    {
                        <form asp-action="Cancel" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Вы уверены, что хотите отменить этот заказ? Материалы будут возвращены на склад.')">Отменить</button>
                        </form>
                    }
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Вы уверены, что хотите удалить заказ #@item.Id?')">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        // Функция для расчета и анимации прогресс-баров на основе времени
        function updateProgressBars() {
            const bars = document.querySelectorAll('.real-time-progress');
            const now = new Date();

            bars.forEach(bar => {
                // Если заказ уже завершен (100%), можно пропустить или оставить 100%
                // Но для визуальной точности пересчитаем
                const startStr = bar.getAttribute('data-start');
                const endStr = bar.getAttribute('data-end');

                const start = new Date(startStr);
                const end = new Date(endStr);

                if (isNaN(start) || isNaN(end)) return;

                const totalDuration = end - start;
                if (totalDuration <= 0) return; // Защита от деления на ноль

                const elapsed = now - start;
                let percent = (elapsed / totalDuration) * 100;

                // Ограничиваем от 0 до 100
                if (percent < 0) percent = 0;
                if (percent > 100) percent = 100;

                const rounded = Math.round(percent);

                // Обновляем визуальную часть
                bar.style.width = rounded + '%';
                bar.textContent = rounded + '%';
                bar.setAttribute('aria-valuenow', rounded);
                
                // Если 100%, меняем цвет на зеленый (Bootstrap класс)
                if (rounded === 100) {
                    bar.classList.add('bg-success');
                } else {
                    bar.classList.remove('bg-success');
                }
            });
        }

        // Запускаем сразу при загрузке и повторяем каждую секунду
        document.addEventListener('DOMContentLoaded', function() {
            updateProgressBars();
            setInterval(updateProgressBars, 1000);
        });
    </script>
}