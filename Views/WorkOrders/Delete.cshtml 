@model ProductionManagementSystem.Web.Models.WorkOrder

@{
    ViewData["Title"] = "Удалить заказ";
}

<h2>@ViewData["Title"]</h2>

<h3>Вы уверены, что хотите удалить этот заказ?</h3>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Номер заказа</dt>
            <dd class="col-sm-9">@Model.Id</dd>
            
            <dt class="col-sm-3">Продукт</dt>
            <dd class="col-sm-9">@Model.Product?.Name</dd>
            
            <dt class="col-sm-3">Количество</dt>
            <dd class="col-sm-9">@Model.Quantity</dd>
            
            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">
                @(Model.Status switch
                {
                    "Pending" => "Ожидает",
                    "InProgress" => "В процессе",
                    "Completed" => "Завершён",
                    "Cancelled" => "Отменён",
                    _ => Model.Status
                })
            </dd>
            
            <dt class="col-sm-3">Дата начала</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd.MM.yyyy")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>